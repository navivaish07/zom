#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>

int main() {

    pid_t pid;

    pid = fork();

    if(pid > 0) {

        printf("Parent Process Exiting\n");

    }

    else if(pid == 0) {

        sleep(5);

        printf("Child Process Running\n");
        printf("Orphan Process ID = %d\n", getpid());

    }

    return 0;
}
